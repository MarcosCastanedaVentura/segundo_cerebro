# Copia este fichero a .env y rellena las claves reales. .env nunca se commitea (ver .gitignore).

# OpenAI — usado para generar embeddings (text-embedding-3-small). Es la única clave obligatoria:
# el OCR (MinerU) corre local y gratis, sin API.
OPENAI_API_KEY=

# Mathpix Convert API — upgrade opcional y de pago para OCR de fórmulas si en algún momento MinerU
# se queda corto en asignaturas concretas (química, ecuaciones diferenciales manuscritas...).
# No usado por defecto: ingest/extract.py usa MinerU. Ver https://mathpix.com/pricing/api
# MATHPIX_APP_ID=
# MATHPIX_APP_KEY=
